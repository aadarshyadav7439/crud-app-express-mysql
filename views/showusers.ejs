<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>users</title>
    
    <style>
        table,tr,td,th{
            border: 1px solid black;
            margin: 1 rem;
        }
        th{
            background-color: rgb(231, 175, 184);
        }
        td{
            background-color: antiquewhite;
        }
    </style>
</head>
<body>
    <table>
        <tr>
            <th>ID</th>
            <th>Email Id</th>
            <th>Username</th>
        </tr>

        <%for(u of users){%>
            <tr>
                <td><%=u.id%></td>
                <td><%=u.email%></td>
                <td><%=u.username%></td>
                <td>
                    <form action="/user/<%= u.id %>/edit" method="get">
                        <button>Edit Username</button>
                    </form>
                </td>
                <td>
                    <form action="/user/<%= u.id %>/delete" method="GET">
                        <button>Delete</button>
                    </form>
                </td>
                
            </tr>
        <% } %>
    </table>
</body>
</html>
